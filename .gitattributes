# Auto-detect text files and normalize line endings
* text=auto

# Mark binary/generated files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.rds binary
*.xlsx binary
*.csv.gz binary

# Mark large data files as binary (for better diff handling)
files/**/*.csv binary
files/**/*.tsv binary

# Linguist: exclude generated files from language stats
skills/**/*.md linguist-generated=true
skills/**/*.json linguist-generated=true
_site/** linguist-generated=true
_freeze/** linguist-generated=true
